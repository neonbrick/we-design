{
  "name": "we-design",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "We design — AI-generated one-page websites for small businesses.",
  "scripts": {
    "generate": "tsx scripts/generate-copy.ts",
    "build": "tsc --noEmit && tsx scripts/build-site.ts",
    "preview": "python3 -m http.server --directory dist 4173",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
